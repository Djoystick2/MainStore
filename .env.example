# MainStore environment template.
# Copy this file to `.env.local` for local development.
# IMPORTANT: never commit real secrets.

# ================================================
# Public runtime variables (exposed to browser)
# ================================================

# Supabase project URL.
# Example: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (safe for client usage with RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ================================================
# Server-only runtime variables (MUST stay secret)
# ================================================

# Supabase service role key.
# Required for server-side profile upsert, user mutations, checkout, and admin CRUD.
SUPABASE_SERVICE_ROLE_KEY=

# Telegram Bot token.
# Required for server-side Telegram init-data verification.
TELEGRAM_BOT_TOKEN=

# Secret used to sign app session cookie.
# Use a long random value.
APP_SESSION_SECRET=

# ================================================
# Payments
# ================================================

# Active runtime payment provider.
# Supported right now: sandbox
# Leave empty to use the default registered provider.
PAYMENT_PROVIDER=sandbox

# Optional webhook secret for sandbox testing.
# If set, send the same value in `x-payment-webhook-secret`.
PAYMENT_SANDBOX_WEBHOOK_SECRET=

# ================================================
# Optional / dev-only notes
# ================================================

# NODE_ENV is managed by Next.js commands (`dev`, `build`, `start`).
# Real provider-specific secrets are intentionally not defined here until a concrete
# payment gateway is selected and documented.
